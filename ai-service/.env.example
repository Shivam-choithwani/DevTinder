# DevTinder Recommendation Backend Configuration

# MongoDB Atlas Setup
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=devtinder

# Gemini API Key (Free tier via Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (Optional but recommended to prevent rate limits)
GITHUB_TOKEN=your_github_token_here

# Optional: Host & Port Configuration
HOST=0.0.0.0
PORT=8000
